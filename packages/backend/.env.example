NODE_ENV=production 
MONGODB_URI=mongodb://localhost:27017/chess_opening_master
MONGODB_DB_NAME=chess-opening-master
MONGODB_BACKUP_DIR=.mongo-backups
BACKEND_PORT=3001
CORS_ORIGIN=http://localhost:3002,http://127.0.0.1:3002
ENABLE_AUTH=false
ALLOW_DEFAULT_USER=false
DEFAULT_USER_USERNAME=default
GAME_PROVIDER_TOKEN_SECRET=replace-with-a-strong-random-secret
MIGRATIONS_AUTO_RUN=false
MIGRATIONS_LEASE_MS=600000
ENABLE_GAMES_AUTO_SYNC=false
GAMES_AUTO_SYNC_INTERVAL_MS=86400000
GAMES_AUTO_SYNC_BATCH_SIZE=25
GAMES_AUTO_SYNC_SHUTDOWN_TIMEOUT_MS=30000
GAMES_AUTO_SYNC_DUE_HOURS=24
